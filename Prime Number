#include<iostream>

using namespace std;

int main()
{
    int N, i, flag=0;
    cout<<"ENter any digit to check its prime or not"<<endl;
    cin>>N;

    if (N <= 1) {
        cout << "This is not prime" << endl;
        return 0;
    }

    for ( i = 2; i <= N/2; i++)
    {
        if (N%i==0)
        {
        
        flag = 1;
        break;
        }
       
        
    }

    if (flag == 0) {
        cout << "This is a prime number" << endl;
    } else {
        cout << "This is not a prime number" << endl;
    }

    return 0;
    
}
