#include<iostream>

using namespace std;
int main()
{

    int temp, rem, reverse=0, n;

    cout<<"Enter N digit for check palindrom"<<endl;
    cin>>n;

     temp=n;
    while (temp !=0)
    {
        rem=temp % 10;
        reverse = reverse*10+rem;
        temp=temp/10;
    }
    
    if (n==reverse)
    {

        cout<<"Yes This is Palindrome"<<endl;
    }
    else
    cout<<"Sorry! This is not palindrome";
    
    
    return 0;

    

}
