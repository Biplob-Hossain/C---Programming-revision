#include<iostream>

using namespace std;
int main()
{

    int n, temp, sum=0, reminder;

    cout<<"Enter any Digit to chek Armstrong"<<endl;
    cin>>n;

    temp=n;

    while (temp!=0)
    {
        reminder=temp%10;
        sum=sum+(reminder*reminder*reminder);
        temp=temp/10;
    }
    if ( n==sum)
    {
        cout<<"Yes! This is armstrong"<<endl;
    }
    else
    cout<<"Sorry! This is not armstrong";
    

}
